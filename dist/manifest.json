{
  "manifest_version": 3,
  "name": "Flowzi",
  "short_name": "FZ",
  "version": "1.0",
  "description": "Ferramenta de captura, notas e atalhos rápidos para turbinar sua produtividade.",
  "permissions": ["storage", "activeTab", "unlimitedStorage", "clipboardRead", "clipboardWrite"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_title": "Flowzi",
    "default_icon": "logo.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "take_screenshot": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Capturar tela (Snip)"
    }
  }
}
